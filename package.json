{
  "name": "solana-helm",
  "version": "0.1.0",
  "description": "DX toolkit for Solana and EVM — schema sync, polyfills, codegen, and workspace orchestration",
  "type": "module",
  "bin": {
    "helm": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./vite": "./src/adapters/vite/index.ts",
    "./webpack": "./src/adapters/webpack/index.ts",
    "./nuxt": "./src/adapters/nuxt/index.ts",
    "./next": "./src/adapters/next/index.ts",
    "./sveltekit": "./src/adapters/sveltekit/index.ts",
    "./remix": "./src/adapters/remix/index.ts",
    "./codegen": "./src/codegen/index.ts",
    "./workspace": "./src/workspace/index.ts",
    "./chains/svm": "./src/chains/svm/index.ts",
    "./chains/evm": "./src/chains/evm/index.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "citty": "^0.1.6",
    "consola": "^3.4.0",
    "defu": "^6.1.4",
    "jiti": "^2.4.0",
    "pathe": "^2.0.0"
  },
  "devDependencies": {
    "@nuxt/kit": "^4.4.2",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0",
    "webpack": "^5.0.0",
    "next": ">=13.0.0",
    "@nuxt/kit": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "@nuxt/kit": {
      "optional": true
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jynxbt/helm"
  },
  "keywords": [
    "solana",
    "vite",
    "anchor",
    "idl",
    "polyfill",
    "codegen",
    "hmr",
    "nextjs",
    "nuxt",
    "sveltekit",
    "remix",
    "webpack",
    "evm",
    "ethereum",
    "hardhat",
    "foundry",
    "viem",
    "ethers",
    "abi"
  ]
}
